{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    ".opencode/plugins/graphify.js"
  ],
  "permission": {
    "glob": "allow",
    "grep": "allow",
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny"
    },
    "edit": "allow",
    "webfetch": "allow",
    "todowrite": "allow",
    "websearch": "allow",
    "question": "allow",
    "lsp": "allow",
    "skill": "allow",
    "external_directory": "ask",
    "bash": {
      "*": "ask",
      "git *": "allow",
      "npm *": "allow",
      "npx *": "allow",
      "python3 *": "allow",
      "cat *": "allow",
      "ls *": "allow",
      "curl *": "allow",
      "pkill *": "ask",
      "rm *": "ask",
      "rmdir *": "ask",
      "git checkout *": "ask",
      "git push *": "allow"
    }
  }
}