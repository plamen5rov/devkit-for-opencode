{
  "$schema": "https://opencode.ai/config.json",
  "model": "anthropic/claude-sonnet-4-20250514",
  "small_model": "anthropic/claude-haiku-4-20250313",
  "share": "manual",
  "snapshot": true,
  "permission": {
    "*": "ask",
    "edit": "allow",
    "bash": "allow",
    "webfetch": "allow",
    "read": "allow",
    "glob": "allow",
    "grep": "allow"
  },
  "plugin": [
    "opencode-wakatime@1.2.0"
  ],
  "mcp": {
    "servers": {
      "context7": {
        "url": "https://mcp.context7.com/mcp",
        "enabled": true
      }
    }
  },
  "agent": {
    "explore": {
      "disabled": false,
      "model": "anthropic/claude-haiku-4-20250313",
      "prompt": "Fast agent specialized for exploring codebases."
    },
    "general": {
      "disabled": false,
      "prompt": "General-purpose agent for research and multi-step tasks."
    }
  }
}
