# OpenCode API key (required for LLM calls)
OPENAI_API_KEY=sk-...

# Optional: Anthropic API key
ANTHROPIC_API_KEY=sk-ant-...

# Optional: OpenCode Zen API key
OPENCODE_API_KEY=...

# Optional: LLM model override (default: from config)
DEVKIT_MODEL=anthropic/claude-sonnet-4-20250514

# Optional: Log level (DEBUG, INFO, WARNING, ERROR)
DEVKIT_LOG_LEVEL=INFO
